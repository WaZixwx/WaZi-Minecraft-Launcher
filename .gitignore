# Gradle 相关 | Gradle Related
.gradle/
build/
gradle-app.setting
.gradletasknamecache
out/

# gradle目录整体不应被忽略，只忽略特定文件 | Don't ignore entire gradle directory
# 但忽略其他gradle目录内容 | But ignore other gradle contents
gradle/*
# 保留 gradle-wrapper目录和jar | Allow gradle-wrapper directory and jar
!gradle/wrapper/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

